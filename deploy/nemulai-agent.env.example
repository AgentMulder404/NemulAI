# NemulAI Agent — environment configuration
# Copy to /etc/nemulai/agent.env and fill in your values.
# Set permissions: chmod 600 /etc/nemulai/agent.env
#
# Full option reference: https://nemulai.com/docs/agent#configuration

# ── Required ──────────────────────────────────────────────────────────────────

ALUMINATAI_API_KEY=alum_your_key_here

# ── Optional: change if self-hosting ─────────────────────────────────────────

# ALUMINATAI_API_ENDPOINT=https://nemulai.com/api/metrics/ingest

# ── Sampling & upload ─────────────────────────────────────────────────────────

# SAMPLE_INTERVAL=5.0        # seconds between NVML samples
# UPLOAD_INTERVAL=60         # seconds between metric flushes
# UPLOAD_BATCH_SIZE=100      # metrics per HTTP request
# HEARTBEAT_INTERVAL=300     # seconds between heartbeat pings

# ── WAL (offline buffer) ─────────────────────────────────────────────────────

# WAL_MAX_MB=512             # max WAL size before oldest rows are dropped
# WAL_MAX_AGE_HOURS=24       # rows older than this are discarded on replay

# ── Prometheus ────────────────────────────────────────────────────────────────

# METRICS_PORT=9100          # 0 = disabled
# METRICS_BIND_HOST=127.0.0.1
# METRICS_BASIC_AUTH=        # user:pass  — enable HTTP Basic Auth

# ── Run mode ─────────────────────────────────────────────────────────────────

# DRY_RUN=0                  # 1 = collect/attribute but skip all uploads
# PROMETHEUS_ONLY=0          # 1 = local Prometheus only, no cloud upload
# OFFLINE_MODE=0             # 1 = WAL only, no HTTP (air-gapped clusters)

# ── Logging ──────────────────────────────────────────────────────────────────

# LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
# LOG_FORMAT=text            # text | json (json for ELK/Loki/Grafana)

# ── Attribution ──────────────────────────────────────────────────────────────

# ALUMINATAI_TRUSTED_UIDS=   # comma-separated UIDs allowed to self-tag; empty = all
# ALUMINATAI_ATTRIBUTION_CONFIG=  # path to attribution_rules.json
